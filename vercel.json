{
  "redirects": [
    { "source": "/post/:slug", "destination": "/blog/:slug", "permanent": true },
    { "source": "/blog-post/:slug", "destination": "/blog/:slug", "permanent": true },
    { "source": "/shop", "destination": "/store", "permanent": true },
    { "source": "/music", "destination": "/resources", "permanent": true },
    { "source": "/media", "destination": "/resources", "permanent": true }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
